#!/usr/bin/env bash

VER="3.4.5"

ver_msg() { echo -e "\njay v$VER\n"; }

set -o pipefail
REAL_HOME=$(getent passwd "${SUDO_USER:-$USER}" 2>/dev/null | cut -d: -f6); REAL_HOME=${REAL_HOME:-$HOME}

LOG_FILE="$REAL_HOME/.cache/jay.log"

CYAN='\033[0;36m'; GREEN='\033[0;32m'; YELLOW='\033[1;33m'; RED='\033[0;31m'; NC='\033[0m'; ALERT="[!]"; ERROR="[x]"; COMPLETE="[✓]"; NOTE="[*]"; CC=":: "

step() { echo -e "${CYAN} $CC ${NC}${1}"; }
success() { echo -e "${GREEN} $COMPLETE ${NC}${1}"; }
error() { echo -e "${RED} $ERROR ${NC}${1}"; exit 1; }

err01() { echo -e "$ALERT invalid argument '$ACTION'"; exit 1; }
err02() { echo -e "${RED}$ERROR Cannot create temporary file"; exit 1; }
err03() { echo -e "${RED}$ERROR yay not found"; exit 1; }
usage() { echo -e "Usage: jay [command] [options] [packages]"; exit 1; }

## START OF COMANDS SESSION

## BASE

help_message() {
    ver_msg
    echo -e "Uso: jay [comando] [opções] [pacotes]"
    echo -e "Uso: jay [ -i | -rm | -s | -u ] [ -f | --flatpak ] [ --noconfirm ]"
    echo -e "Uso: jay [ -q | query ] [ --list-aur ]"
    echo -e "Options:\n"
    echo -e "-h, --help            Show this message again"
    echo -e "-i, install           Sync/install packages"
    echo -e "-rm, remove           Remove packages (Use '-A' to activate the Agressive mode)"
    echo -e "-u, update            Update the system"
    echo -e "-r, refresh           Refresh and upgrade the system"
    echo -e "-s, search            search packages in AUR"
    echo -e "-q, query             Query local packages"
    echo -e "-p, --path-to-binary  Search for binary path"
    echo -e "-o, orphan            Remove non-necessary packages"
    echo -e "-c, cache             Clear all pacman cache"
    echo -e "-m, mirrors           Search for faster repos"
    echo -e "--check-updates       Search for avaliable updates"
    echo -e "--fix-keys            Restore invalid GPG keys"
    exit 0
}

run_flatpak() {
    [[ "$USE_FLATPAK" != "true" ]] && return
    command -v flatpak &>/dev/null || return
    case "$ACTION" in
        update|-u)
            step "Updating Flatpaks..."
            flatpak update -y 2>&1 | tee -a "$TMP_OUT"
            FLAT_EXIT=${PIPESTATUS[0]}
            if [[ $FLAT_EXIT -eq 0 ]]; then
                if grep -qiE "nothing to do|nada a fazer" "$TMP_OUT"; then
                    logger "SKIPPED (flatpak)" "${RAW_CMD}"
                else
                    logger "UPDATED (flatpak)" "${RAW_CMD}"
                fi
            fi
            EXIT_CODE=$FLAT_EXIT
        ;;
        search|-s)
            [[ -n "$FLAT_CMD" ]] && step "Searching in Flatpak..." && flatpak "$FLAT_CMD" "${FINAL_ARGS[@]}"
        ;;
        *)
            if [[ $EXIT_CODE -ne 0 && -n "$FLAT_CMD" ]] && grep -qiE "target not found|Nenhum pacote" "$TMP_OUT"; then
                echo -e "\n${YELLOW} $NOTE AUR failed. Trying Flatpak...${NC}\n"
                flatpak "$FLAT_CMD" -y "${FINAL_ARGS[@]}"
                EXIT_CODE=$?
                [[ $EXIT_CODE -eq 0 ]] && TAG="FLATPAK"
            fi
        ;;
    esac
}

tester() {
    step "Testing network..."
    ping -c 1 8.8.8.8 &>/dev/null || error "Network disconected. Verify your Wi-Fi/Cable."
    success "Connection is active."
}

ins() {
    tester
    CMD="-S"
    TAG="INSTALLED"
    FLAT_CMD="install"
}

rmv() {
    CMD=$([[ "$AGRESSIVE_MODE" == "true" ]] && echo "-Rsn" || echo "-Rs")
    TAG=$([[ "$AGRESSIVE_MODE" == "true" ]] && echo "REMOVE-AGRESSIVE" || echo "REMOVED")
    FLAT_CMD="uninstall"
}

upd() {
    tester
    CMD="-Syu"
    TAG="UPDATED"
    FLAT_CMD="update"
}

rfs() {
    tester
    CMD="-Syyu"
    TAG="REFRESHED MIRRORS & SYSTEM UPGRADED"
    FLAT_CMD="SKIP"
}

## CACHE

clr_cache() {
    if [[ -d "$REAL_HOME/.cache/yay" ]]; then
        step "Cleaning AUR builds..."
        find "$REAL_HOME/.cache/yay" -maxdepth 1 -type d \
        -not -path "$REAL_HOME/.cache/yay" -exec rm -rf {} +
        success "Builds cleaned."
    fi
    if command -v flatpak &>/dev/null; then
        step "Cleaning unused Flatpaks..."
        flatpak uninstall --unused -y &>/dev/null
        success "Flatpaks cleaned."
    fi
    step "Cleaning pacman cache..."
    CMD="-Sc"
    TAG="CLEANED CACHE"
}

remove_orphans() {
    step "Searching for orphan packages..."
    mapfile -t FINAL_ARGS < <(yay -Qqtd 2>/dev/null)
    ORPHANS_N=${#FINAL_ARGS[@]}
    if [[ "$ORPHANS_N" -eq 0 ]]; then
        success "No orphan packages found"
        logger "SEARCHED ORPHANS" "clean"
        exit 0
    fi
    echo "$NOTE $ORPHANS_N Orphans found"
    printf '%s\n' "${FINAL_ARGS[@]}"
    step "Removing orphans..."
    CMD="-Rsn"
    TAG="REMOVED ORPHANS"
}

check_conf() {
    step "Searching for .pacnew/.pacsave files..."
    PACNEWS=$(find /etc -regextype posix-extended \
    -regex ".+\.pac(new|save)" 2>/dev/null)
    if [[ -z "$PACNEWS" ]]; then
        success "All clear! No conflicts found in /etc."
    else
        echo -e "${YELLOW} $NOTE Pending files found:${NC}"
        echo "$PACNEWS"
        echo -e "\n${CYAN} $CC ${NC}Merge now with pacdiff? [y/N]"
        read -r -n 1 opt
        echo
        [[ "$opt" =~ ^(y|Y)$ ]] && sudo pacdiff
    fi
    TAG="CLEAR DIFFS"
}

## BASE2

list_aur() {
    step "Filtering packages installed via AUR..."
    pacman -Qm | column -t
    TAG="LOCAL_QUERY (AUR)"
    local count=$(yay -Qm | wc -l)
    echo -e "\n${GREEN}$COMPLETE${NC} Total of $count AUR packages found."
}

refresh_mirrors() {
    step "Starting mirror optimization (Reflector)..."
    if ! command -v reflector &>/dev/null; then
        echo -e "${YELLOW}$NOTE Reflector not found.${NC}"
        read -p "Do you want to install reflector to optimize mirrors? [Y/n] " -n 1 -r
        echo
        if [[ $REPLY =~ ^[Yy]$ ]]; then
            sudo pacman -S reflector --noconfirm
        else
            error "Reflector is required for this function."
        fi
    fi
    
    step "Creating backup at /etc/pacman.d/mirrorlist.bak"
    sudo cp /etc/pacman.d/mirrorlist /etc/pacman.d/mirrorlist.bak
    step "Fetching the 10 fastest mirrors... (Please wait)"
    if sudo reflector --latest 20 --protocol https --sort rate --save /etc/pacman.d/mirrorlist; then
        success "Mirrors updated and saved successfully."
        TAG="UPDATE MIRRORS"
    else
        error "Failed to update mirrors. Check your internet connection."
    fi
}

fix_keys() {
    step "Starting GPG key recovery..."
    yay -S archlinux-keyring --noconfirm --needed &>/dev/null
    if [[ -f "$TMP_OUT" ]]; then
        local keys=$(grep -oP '(?<=key\s)([A-F0-9]{16,})|(?<=ID\s)([A-F0-9]{16,})' "$TMP_OUT" | sort -u)
        
        if [[ -n "$keys" ]]; then
            for key in $keys; do
                step "Importing key: $key"
                gpg --recv-keys "$key" || gpg --keyserver hkp://keyserver.ubuntu.com:80 --recv-keys "$key"
            done
        fi
    fi
    step "Cleaning corrupted key caches..."
    sudo find /etc/pacman.d/gnupg -type f -name "*.lck" -delete
    sudo pacman-key --init
    sudo pacman-key --populate archlinux
    
    success "Key recovery procedure finished."
    TAG="SKIP"
}

## LOGGER

log_acts() {
    case "$LOG_FUNC" in
        "sl")
            [[ ! -s "$LOG_FILE" ]] && echo "$NOTE The log file is empty." && exit 0
            cat "$LOG_FILE"
            exit 0
        ;;
        "cl")
            > "$LOG_FILE"
            echo "$COMPLETE Cleared log file"
            exit 0
        ;;
    esac
}

logger() {
    local status="${EXIT_CODE:-0}"
    local tag="$1"
    local info="$2"
    printf -v date_str '%(%Y-%m-%d - %H:%M:%S)T' -1
    echo "[$date_str] [EXIT STATUS $status] [$tag] -> $info" >> "$LOG_FILE"
}

## SEARCH

searcher() {
    tester
    CMD="-Ss"
    TAG="SEARCHED"
    FLAT_CMD="search"
}

query() {
    CMD="-Qs"
    TAG="LOCAL QUERY"
    [[ "$LIST_AUR" == true ]] && list_aur && TAG="SKIP" && return
    [[ "$PTBIN" == true ]] && get_package_path "${FINAL_ARGS[@]}" && TAG="SKIP" && return
}

check_updates() {
    tester
    if ! command -v checkupdates 2>/dev/null; then
        step "pacman-contrib not found. Installing..."
        yay -S pacman-contrib --noconfirm
    fi
    step "Searching for updates..."
    raw_upds=$(checkupdates 2>/dev/null)
    raw_aur=$(yay -Qua 2>/dev/null)
    [[ -n "$raw_upds" ]] && UPDS_N=$(echo "$raw_upds" | grep -c .) || UPDS_N=0
    [[ -n "$raw_aur" ]] && UPDS_AUR_N=$(echo "$raw_aur" | grep -c .) || UPDS_AUR_N=0
    if [[ "$UPDS_N" -eq 0 && "$UPDS_AUR_N" -eq 0 ]]; then
        success "nothing to do."
        logger "NO UPDATES FOUND" "$((UPDS_N + UPDS_AUR_N)) updates ($UPDS_AUR_N in AUR)"
        exit 0
    fi
    echo -e "${YELLOW} $NOTE $((UPDS_N + UPDS_AUR_N)) Updates found ($UPDS_AUR_N in AUR):${NC}"
    [[ "$UPDS_N" -gt 0 ]] && echo -e "${CYAN}$raw_upds ${NC}"
    [[ "$UPDS_AUR_N" -gt 0 ]] && echo -e "${GREEN}$raw_aur ${NC}"
    logger "FOUND UPDATES" "$((UPDS_N + UPDS_AUR_N)) updates ($UPDS_AUR_N in AUR)"
}

get_package_path() {
    local pkg="$1"
    [[ -z "$pkg" ]] && echo "$ALERT Provide a package name." && exit 1
    if pacman -Qi "$pkg" &>/dev/null; then
        step "Files for package: ${pkg}"
        local bins=$(pacman -Ql "$pkg" | grep '/bin/' | cut -d' ' -f2-)
        if [[ -n "$bins" ]]; then
            echo -e "${GREEN}Binaries found:${NC}"
            echo "$bins"
        else
            echo -e "${YELLOW}No binaries found. Displaying all files instead:${NC}"
            pacman -Ql "$pkg" | cut -d' ' -f2- | less
        fi
        logger "PATH SEARCH" "$pkg"
    else
        logger "PATH SEARCH FAILED" "$pkg"
        echo "$ALERT Package '$pkg' is not installed."; exit 1
    fi
}

## END OF COMMANDS SESSION

[[ -f "$LOG_FILE" ]] || touch "$LOG_FILE"
[[ ! -w "$LOG_FILE" ]] && sudo chown "${SUDO_USER:-$USER}":"${SUDO_USER:-$USER}" "$LOG_FILE" 2>/dev/null
[[ -z "$1" ]] && usage

RAW_CMD="$*"; USE_FLATPAK=false; PTBIN=false; AGRESSIVE_MODE=false; FINAL_ARGS=(); YAY_FLAGS=(); EXIT_CODE=0; KILL_DBLOCK=false; LIST_AUR=false

for arg in "$@"; do
    case "$arg" in
        install|-i|remove|-rm|update|-u|search|-s|query|-q|cache|-c|orphan|-o|mirrors|-m|refresh|-r|slog|-sl|--fix-keys|clog|-cl|--check-updates) [[ -z "$ACTION" ]] && ACTION="$arg" || FINAL_ARGS+=("$arg") ;;
        --kill-dblock) KILL_DBLOCK=true ;;
        -h|--help) help_message ;;
        -f|--flatpak) USE_FLATPAK=true ;;
        -v|--version) ver_msg; exit 0 ;;
        -A) AGRESSIVE_MODE=true ;;
        --list-aur) LIST_AUR=true ;;
        -p|--path-to-binary) PTBIN=true ;;
        -) ACTION="-" && err01 ;;
        -*) YAY_FLAGS+=("$arg") ;;
        *) FINAL_ARGS+=("$arg") ;;
    esac
done

[[ -z "$ACTION" && ${#FINAL_ARGS[@]} -gt 0 ]] && ACTION="${FINAL_ARGS[0]}" && FINAL_ARGS=("${FINAL_ARGS[@]:1}")
[[ -z "$ACTION" ]] && ACTION="${YAY_FLAGS[0]:-$1}" && err01

[[ "$ACTION" =~ ^(install|remove|-i|-rm)$ && ${#FINAL_ARGS[@]} -eq 0 ]] && error "specify at least one package"
command -v yay &>/dev/null || err03

TMP_OUT=$(mktemp) || err02
trap 'rm -f "$TMP_OUT" 2>/dev/null' EXIT

if [[ -n "$ACTION" ]]; then
    [[ "$AGRESSIVE_MODE" == "true" ]] && echo -e "${RED} $NOTE Agressive mode enabled!${NC}"
    [[ ! "$ACTION" =~ ^(-m|mirrors|-sl|-cl|slog|clog)$ ]] && step "Executing: $ACTION"
fi
if [[ "$KILL_DBLOCK" == "true" ]]; then
    pgrep -x "pacman|yay" &>/dev/null && error "Pacman/yay is already running."
    [[ -f /var/lib/pacman/db.lck ]] && sudo rm /var/lib/pacman/db.lck && success "Database lock removed."
fi

case "$ACTION" in
    slog|-sl) LOG_FUNC="sl"; log_acts ;;
    clog|-cl) LOG_FUNC="cl"; log_acts ;;
    install|-i) ins ;;
    remove|-rm) rmv ;;
    refresh|-r) rfs ;;
    update|-u) upd ;;
    search|-s) searcher ;;
    query|-q) query ;;
    cache|-c) clr_cache ;;
    orphan|-o) remove_orphans ;;
    mirrors|-m) refresh_mirrors ;;
    --check-updates) check_updates ;;
    --fix-keys) fix_keys ;;
    *) err01 ;;
esac

[[ "$TAG" == "SKIP" ]] && exit 0

case "$ACTION" in
    search|-s) yay "$CMD" "${FINAL_ARGS[@]}" "${YAY_FLAGS[@]}" 2>&1 | tee "$TMP_OUT"; EXIT_CODE=${PIPESTATUS[0]}; run_flatpak ;;
    *) if [[ -n "$CMD" ]]; then
            yay "$CMD" "${FINAL_ARGS[@]}" "${YAY_FLAGS[@]}" 2>&1 | tee "$TMP_OUT"
            EXIT_CODE=${PIPESTATUS[0]}
            run_flatpak
        fi
    ;;
esac

if [[ "$EXIT_CODE" -eq 0 && -n "$TAG" ]]; then
    if grep -qiE "could not find|nenhum pacote|target not found" "$TMP_OUT"; then
        logger "NOT FOUND" "${RAW_CMD}"
    else
        logger "${TAG:-SYSTEM}" "${RAW_CMD}"
    fi
fi
