#!/usr/bin/env bash

# --- Configurações Gerais ---
VER="1.3.5"
LOG_FILE="$HOME/.cache/jaylog.txt"
[[ -f "$LOG_FILE" ]] || touch "$LOG_FILE"

# Cores para o Terminal (Apenas exibição)
GREEN='\e[32m'
RED='\e[31m'
YELLOW='\e[33m'
BOLD='\e[1m'
NC='\e[0m'

# --- Funções de Apoio ---

# Limpa códigos ANSI (cores) de uma string
clean_ansi() {
    echo "$1" | sed 's/\x1b\[[0-9;]*[mGJK]//g'
}

log_action() {
    local exit_code=$1
    local tag=$2
    local info=$3
    local date_str
    date_str=$(date "+%H:%M - %d/%m/%Y")

    # Garante que o log seja sempre texto puro
    local c_tag=$(clean_ansi "$tag")
    local c_info=$(clean_ansi "$info")

    if [[ $exit_code -eq 0 ]]; then
        echo "($date_str) | $c_tag | $c_info" >> "$LOG_FILE"
    else
        echo "($date_str) | [ERROR] | $c_tag $c_info" >> "$LOG_FILE"
    fi
}

usage() {
    echo -e "${YELLOW}Uso:${NC} jay [comando] [pacotes]"
    exit 1
}

# --- Lógica de Comandos ---

[[ -z "$1" ]] && usage

case "$1" in
    install) CMD="-S";   TAG="[INSTALLED]" ;;
    remove)  CMD="-Rsn"; TAG="[REMOVED]"   ;;
    refresh) CMD="-Syy"; TAG="[REFRESHED]" ;;
    update)  CMD="-Syu"; TAG="[UPDATED]"   ;;
    search)  CMD="-Ss";  TAG="SKIP"        ;;
    query)   CMD="-Qs";  TAG="SKIP"        ;;
    cache)   CMD="-Sc";  TAG="[CACHE CLEAN]" ;;
    slog)
        [[ ! -s "$LOG_FILE" ]] && { echo "Log vazio."; exit 0; }
        # Aplica cores apenas na hora de mostrar na tela
        sed -e "s/\[INSTALLED\]/${GREEN}&${NC}/g" \
            -e "s/\[REMOVED\]/${RED}&${NC}/g" \
            -e "s/\[ERROR\]/${RED}${BOLD}&${NC}/g" \
            -e "s/\[UPDATED\]/${YELLOW}&${NC}/g" "$LOG_FILE" | column -t -s '|'
        exit 0 ;;
    clog) > "$LOG_FILE"; echo "Logs limpos."; exit 0 ;;
    --comp-setup) 
        # (Sua lógica de completion aqui...)
        echo "Completions configuradas!"; exit 0 ;;
    -v|--version) echo "jay v$VER"; exit 0 ;;
    *) usage ;;
esac

# --- Processamento de Argumentos ---
shift
ARGS=()
NOCONFIRM=""

for arg in "$@"; do
    [[ "$arg" == "--noconfirm" || "$arg" == "-y" ]] && NOCONFIRM="--noconfirm" || ARGS+=("$arg")
done

# Impede rodar comandos vazios que poluem o log
if [[ "$1" =~ ^(install|remove)$ && ${#ARGS[@]} -eq 0 ]]; then
    echo -e "${RED}Erro:${NC} Nenhum pacote especificado."
    exit 1
fi

# --- Execução Principal ---
if ! command -v yay &>/dev/null; then echo "Erro: yay não encontrado."; exit 1; fi

TMP_OUT=$(mktemp)
yay "$CMD" "${ARGS[@]}" $NOCONFIRM 2>&1 | tee "$TMP_OUT"
EXIT_CODE=$?

# --- Registro de Log ---
if [[ "$TAG" != "SKIP" ]]; then
    PKGS_LIST=$(IFS=','; echo "${ARGS[*]}")
    
    # Tratamento especial para o 'update' pegar os nomes dos pacotes
    if [[ "$1" == "update" && $EXIT_CODE -eq 0 ]]; then
        PKGS_LIST=$(clean_ansi "$(cat "$TMP_OUT")" | grep -E "upgraded|atualizado" | awk '{print $3}' | tr '\n' ',' | sed 's/,$//')
    fi

    # Se a lista de pacotes for vazia (ex: update sem nada), usa "SYSTEM"
    log_action $EXIT_CODE "$TAG" "${PKGS_LIST:-SYSTEM}"
fi

rm "$TMP_OUT"